# CI/CD Pipeline -- <%Name%>

stages:
  - ci
  - publish

.pwsh_defaults: &pwsh_defaults
  image: mcr.microsoft.com/powershell:lts-ubuntu-22.04
  before_script:
    - pwsh -File ./build/bootstrap.ps1

ci:linux:
  <<: *pwsh_defaults
  stage: ci
  script:
    - pwsh -Command "Invoke-Build -File ./build/module.build.ps1"
  artifacts:
    when: always
    reports:
      junit: artifacts/testResults/unit-results.xml
    paths:
      - artifacts/testResults/
      - artifacts/package/
      - artifacts/archive/

# Uncomment to run CI on Windows. Requires a self-hosted runner tagged 'windows'.
# GitLab shared runners on gitlab.com are Linux only.
# ci:windows:
#   <<: *pwsh_defaults
#   stage: ci
#   tags:
#     - windows
#   image: null
#   script:
#     - pwsh -Command "Invoke-Build -File ./build/module.build.ps1"
#   artifacts:
#     when: always
#     reports:
#       junit: artifacts/testResults/unit-results.xml

# Setup: add PSGALLERY_API_KEY as a protected, masked CI/CD variable.
publish:
  <<: *pwsh_defaults
  stage: publish
  rules:
    - if: $CI_COMMIT_TAG =~ /^v/
  script:
    - VERSION=$(echo "$CI_COMMIT_TAG" | sed 's/^v//')
    - pwsh -Command "Invoke-Build -File ./build/module.build.ps1 -Task Release -NewVersion '$VERSION'"
  environment:
    name: psgallery
  artifacts:
    paths:
      - artifacts/package/
