# CI/CD Pipeline -- <%ModuleName%>

stages:
  - ci
  - publish

.pwsh_defaults: &pwsh_defaults
  image: mcr.microsoft.com/powershell:lts-ubuntu-22.04
  before_script:
    - pwsh -File ./build/bootstrap.ps1

ci:linux:
  <<: *pwsh_defaults
  stage: ci
  script:
    - pwsh -Command "Invoke-Build -File ./build/module.build.ps1"
  artifacts:
    when: always
    reports:
      junit: artifacts/testResults/unit-results.xml
    paths:
      - artifacts/testResults/
      - artifacts/package/
      - artifacts/archive/

ci:windows:
  <<: *pwsh_defaults
  stage: ci
  tags:
    - windows
  image: null
  script:
    - pwsh -Command "Invoke-Build -File ./build/module.build.ps1"
  artifacts:
    when: always
    reports:
      junit: artifacts/testResults/unit-results.xml

# To enable PSGallery publishing:
#   1. Add PSGALLERY_API_KEY as a protected, masked CI/CD variable
#   2. Uncomment the PSGALLERY_API_KEY variable below
#   3. Change the script to include -Task Release
publish:
  <<: *pwsh_defaults
  stage: publish
  rules:
    - if: $CI_COMMIT_TAG =~ /^v/
  script:
    - |
      $Version = $env:CI_COMMIT_TAG -replace '^v', ''
      if ($Version -notmatch '^\d+\.\d+\.\d+') {
          throw "Invalid version format: '$Version'. Expected semver (e.g., 1.0.0)."
      }
      pwsh -Command "Invoke-Build -File ./build/module.build.ps1 -NewVersion '$Version'"
  # variables:
  #   PSGALLERY_API_KEY: $PSGALLERY_API_KEY
  environment:
    name: production
  artifacts:
    paths:
      - artifacts/package/
