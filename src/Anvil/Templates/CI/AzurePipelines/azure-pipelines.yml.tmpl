trigger:
  branches:
    include:
      - main

pr:
  branches:
    include:
      - main

pool:
  vmImage: 'ubuntu-latest'

stages:
  - stage: Lint
    displayName: 'Lint'
    jobs:
      - job: PSScriptAnalyzer
        steps:
          - task: PowerShell@2
            displayName: 'Bootstrap (Build scope)'
            inputs:
              targetType: filePath
              filePath: ./build/bootstrap.ps1
              arguments: -Scope Build
              pwsh: true
          - task: PowerShell@2
            displayName: 'Run PSScriptAnalyzer'
            inputs:
              targetType: inline
              script: Invoke-Build -File ./build/module.build.ps1 -Task Lint
              pwsh: true

  - stage: Test
    displayName: 'Test'
    dependsOn: Lint
    jobs:
      - job: UnitTests
        strategy:
          matrix:
            linux:
              vmImage: 'ubuntu-latest'
            windows:
              vmImage: 'windows-latest'
            macos:
              vmImage: 'macos-latest'
        pool:
          vmImage: $(vmImage)
        steps:
          - task: PowerShell@2
            displayName: 'Bootstrap'
            inputs:
              targetType: filePath
              filePath: ./build/bootstrap.ps1
              pwsh: true
          - task: PowerShell@2
            displayName: 'Run Pester tests'
            inputs:
              targetType: inline
              script: Invoke-Build -File ./build/module.build.ps1 -Task Test
              pwsh: true
          - task: PublishTestResults@2
            displayName: 'Publish test results'
            condition: always()
            inputs:
              testResultsFormat: NUnit
              testResultsFiles: '**/unit-results.xml'
              searchFolder: ./artifacts/testResults

  - stage: Package
    displayName: 'Package'
    dependsOn: Test
    jobs:
      - job: BuildPackage
        steps:
          - task: PowerShell@2
            displayName: 'Bootstrap'
            inputs:
              targetType: filePath
              filePath: ./build/bootstrap.ps1
              pwsh: true
          - task: PowerShell@2
            displayName: 'Full build'
            inputs:
              targetType: inline
              script: Invoke-Build -File ./build/module.build.ps1
              pwsh: true
          - publish: ./artifacts/package
            artifact: module-package
          - publish: ./artifacts/archive
            artifact: module-archive
