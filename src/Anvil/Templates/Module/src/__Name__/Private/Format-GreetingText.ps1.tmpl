function Format-GreetingText {
    <#
    .SYNOPSIS
        Formats a greeting string.

    .DESCRIPTION
        Sample private function demonstrating the helper pattern.  Uses the
        GreetingBuilder class from PrivateClasses/ to show how functions can
        depend on classes.  Private functions are not exported.
    #>
    [CmdletBinding()]
    [OutputType([string])]
    param(
        [Parameter(Mandatory)]
        [string]$Name
    )

    $Builder = [GreetingBuilder]::new()
    $Builder.Build($Name)
}
