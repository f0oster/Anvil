function Get-Greeting {
    <#
    .SYNOPSIS
        Returns a greeting message.

    .DESCRIPTION
        Sample public function demonstrating the module pattern.  Replace
        this with your own exported functions.

    .PARAMETER Name
        The name to greet.  Defaults to 'World'.

    .OUTPUTS
        System.String

    .EXAMPLE
        Get-Greeting -Name 'Alice'
    #>
    [CmdletBinding()]
    [OutputType([string])]
    param(
        [Parameter(Position = 0)]
        [string]$Name = 'World'
    )

    Format-GreetingText -Name $Name
}
