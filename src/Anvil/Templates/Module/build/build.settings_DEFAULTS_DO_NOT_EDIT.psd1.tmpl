# DEFAULT BUILD SETTINGS -- DO NOT EDIT THIS FILE
#
# This file contains the default values for all build settings.
# To customise the build, edit build.settings.psd1 instead.
# Any setting missing or invalid in build.settings.psd1 will
# fall back to the value defined here.
@{
    ModuleName        = '<%ModuleName%>'
    CoverageThreshold = <%CoverageThreshold%>
    IncludeDocs       = $<%IncludeDocs%>
    TestOutputFormat  = 'NUnitXml'
    TestVerbosity     = 'Detailed'
    LintFailOn        = @('Warning', 'Error')
    AssetDirectories  = @('Types', 'Formats', 'Assemblies')
}
