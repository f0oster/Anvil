# Build settings for <%Name%>
#
# Edit these values to customise the build pipeline. Any setting removed
# or set to an invalid type will fall back to the default in
# build.settings_DEFAULTS_DO_NOT_EDIT.psd1.
@{
    ModuleName        = '<%Name%>'
    CoverageThreshold = <%CoverageThreshold%>
    IncludeDocs       = $<%IncludeDocs%>
    TestOutputFormat  = 'NUnitXml'
    TestVerbosity     = 'Detailed'
    LintFailOn        = @('Warning', 'Error')
    AssetDirectories  = @('Types', 'Formats', 'Assemblies')
}
